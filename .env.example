# ── Gemini AI (backend only) ────────────────────────────────────────────────
# Nunca usar NEXT_PUBLIC_ para chaves de IA.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Google Maps — Frontend ───────────────────────────────────────────────────
# Usado pelo browser para autocomplete de morada (Places API), no modelo Oscar:
# o SDK Google é carregado no cliente e usa AutocompleteService + PlacesService
# com session tokens (predictions grátis; só o getDetails final é faturado).
# Ver src/hooks/useGooglePlaces.ts.
#
# SETUP OBRIGATÓRIO no Google Cloud Console:
#   1. Ativar as APIs: "Maps JavaScript API" + "Places API".
#   2. Application restrictions → HTTP referrers:
#        https://clyon.pt/*  |  https://*.vercel.app/*  |  http://localhost:3000/*
#   3. API restrictions → limitar às 2 APIs acima.
#
# Enquanto esta chave estiver VAZIA, o hook cai automaticamente para o proxy
# servidor (/api/maps/autocomplete) e depois Nominatim — sem quebrar nada.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Google Maps — Backend ────────────────────────────────────────────────────
# Usado APENAS pelo servidor para cálculo de distância (Routes API).
# Nunca expor esta chave ao browser.
# Restringir a chave às APIs: Routes API (server-side).
GOOGLE_MAPS_SERVER_API_KEY=

# ── Localização da base CLYON ────────────────────────────────────────────────
# Coordenadas têm prioridade sobre o endereço (mais rápido e preciso).
# Se não existirem, usa CLYON_BASE_ADDRESS como fallback.
CLYON_BASE_LAT=
CLYON_BASE_LNG=
CLYON_BASE_ADDRESS=Fernão Ferro, Seixal, Portugal

# ── Vercel Blob (upload de fotos) ────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Admin setup (rota segura de inicialização) ───────────────────────────────
# Usado para chamar POST /api/admin/setup e garantir que WANDERSON tem isAdmin=1.
# Gerar com: openssl rand -base64 32
# Depois de executar o setup, pode remover ou manter para uso futuro.
ADMIN_SETUP_SECRET=

# ── Base de dados (Neon Postgres) ─────────────────────────────────────────────
# Obtida no painel Neon → Settings → Connection string
DATABASE_URL=

# ── Autenticação colaboradores ────────────────────────────────────────────────
# Gerar com: openssl rand -base64 32
JWT_SECRET=

# ── Autenticação clientes (Google OAuth via NextAuth) ──────────────────────────
# NEXTAUTH_SECRET: gerar com openssl rand -base64 32 (ou node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
# GOOGLE_CLIENT_ID/SECRET: Google Cloud Console → APIs & Services → Credentials → OAuth client ID (Web application)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Obtida em resend.com → API Keys
RESEND_API_KEY_clyonsite=

# ── Google Calendar ───────────────────────────────────────────────────────────
# Credenciais da Service Account no Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
CLYON_GOOGLE_CALENDAR_ID=
CLYON_GOOGLE_CALENDAR_NAME=

# ── Google Sheets (export de pedidos concluídos) ────────────────────────────────
# Reutiliza a Service Account acima. Partilhar a folha de cálculo (Editor) com o
# email dessa conta, depois colar aqui o ID da folha (parte do URL entre /d/ e /edit).
GOOGLE_SHEETS_SPREADSHEET_ID=

# ── Portal OAuth (colaboradores) ─────────────────────────────────────────────
OAUTH_SERVER_URL=
NEXT_PUBLIC_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=

# ── Forge / App interno ───────────────────────────────────────────────────────
BUILT_IN_FORGE_API_KEY=
BUILT_IN_FORGE_API_URL=
NEXT_PUBLIC_APP_ID=
NEXT_PUBLIC_FRONTEND_FORGE_API_KEY=
CHAT_MODEL=
